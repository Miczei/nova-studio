# --- Phase 3: on-site AI chatbot (Claude) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model for the live agent. Options: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Contact page (/contact): forward form submissions to a webhook ---
# Paste a Make.com / Zapier / Google Apps Script webhook URL that appends a
# row to a Google Sheet. Receives POST JSON: { firstName, lastName, email,
# message, timestamp }. Server-only (never exposed to the client). Until
# this is set, submissions still succeed for visitors but are only logged
# server-side, not forwarded anywhere.
GOOGLE_SHEETS_WEBHOOK_URL=
